generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---
enum Role {
  OWNER
  MANAGER
  RECEPTIONIST
  SUPER_ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  EXPIRED
  CANCELED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// --- Models ---

model Salon {
  id                         String         @id @default(uuid())
  name                       String
  whatsappNumber             String         @unique
  address                    String?
  homeBookingFee             Float          @default(0.0)
  aiPrompt                   String?        // Custom instructions for the AI Receptionist
  whatsappPhoneNumberId      String?        @unique
  whatsappAccessToken        String?
  whatsappBusinessAccountId  String?
  instagramPageId            String?        @unique
  instagramAccessToken       String?
  isProfileComplete          Boolean        @default(false)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  // Owner information fields
  ownerName            String?
  ownerMobile          String?
  ownerAlternateMobile String?
  ownerEmail           String?
  ownerAddress         String?
  ownerCity            String?
  ownerState           String?
  ownerCountry         String?
  gstNumber            String?
  businessCategory     String?

  users           User[]
  customers       Customer[]
  services        Service[]
  staff           Staff[]
  appointments    Appointment[]
  conversations   Conversation[]
  campaigns       Campaign[]
  subscription    Subscription?
  auditLogs       AuditLog[]
  commissions     Commission[]
  cashDrawerLogs  CashDrawerLog[]
  waitingList     WaitingList[]

  // Growth Features fields
  reviewDelayMins   Int                       @default(60)
  googleReviewLink  String?
  rebookingAutoSend Boolean                   @default(false)
  missedCalls       MissedCall[]
  reviewCampaigns   ReviewCampaign[]
  rebookingRules    RebookingRule[]
  rebookingRecommendations RebookingRecommendation[]

  // Daily Report Feature fields
  dailyReportTime         String             @default("20:00")
  dailyReportsEnabled     Boolean            @default(true)
  weeklyReportsEnabled    Boolean            @default(true)
  monthlyReportsEnabled   Boolean            @default(true)
  businessReports         BusinessReport[]

  // Working Hours config
  openingTime             String             @default("10:00")
  closingTime             String             @default("20:00")
}

model Subscription {
  id                String             @id @default(uuid())
  salonId           String             @unique
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  stripeCustomerId  String?
  currentPeriodEnd  DateTime?
  openaiUsageCost   Float              @default(0.0)
  whatsappUsageCost Float              @default(0.0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  salon            Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  salonId   String
  name      String
  email     String   @unique
  password  String?
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon     Salon      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  auditLogs      AuditLog[]
  cashDrawerLogs CashDrawerLog[]
}

model Customer {
  id          String   @id @default(uuid())
  salonId     String
  name        String
  phone       String
  totalVisits Int      @default(0)
  lastVisit   DateTime?
  
  // New UCIS Fields
  gender      String?  // MALE, FEMALE, NON_BINARY, PREFER_NOT_TO_SAY
  dateOfBirth DateTime?
  notes       String?
  source      String   @default("WHATSAPP") // WALK_IN, PHONE, REFERRAL, INSTAGRAM, FACEBOOK, GOOGLE, WHATSAPP, OTHER

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salon         Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  conversations Conversation[]
  reviewCampaigns ReviewCampaign[]
  rebookingRecommendations RebookingRecommendation[]
  waitingList   WaitingList[]

  @@unique([salonId, phone])
}

model Service {
  id           String   @id @default(uuid())
  salonId      String
  name         String
  durationMins Int      // Time in minutes
  price        Float
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  rebookingRule RebookingRule?
  rebookingRecommendations RebookingRecommendation[]
  commissions              Commission[]
  staffServices            StaffService[]
  waitingList   WaitingList[]
}

model Staff {
  id          String   @id @default(uuid())
  salonId     String
  name        String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  commissions  Commission[]
  staffServices StaffService[]
  waitingList   WaitingList[]
}

model StaffService {
  staffId   String
  serviceId String
  createdAt DateTime @default(now())

  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}


model Appointment {
  id         String            @id @default(uuid())
  salonId    String
  customerId String
  serviceId  String
  staffId    String?
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(PENDING)
  
  // New UCIS Fields
  bookingSource String            @default("ONLINE_WHATSAPP") // ONLINE_WHATSAPP, ONLINE_AI, OFFLINE_WALKIN, OFFLINE_PHONE, OFFLINE_DESK, OFFLINE_OTHER
  amountPaid    Float?            // Actual money paid (stores final discounted price)
  notes         String?
  createdById   String?           // Staff/User who recorded this offline entry (Optional)
  durationMins  Int?              // Optional duration override in minutes
  heldUntil     DateTime?         // Temporary hold expiration timestamp for waiting lists

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  salon      Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff      Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  reminder   Reminder?
  reviewCampaign ReviewCampaign?
}

model Reminder {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  scheduledFor  DateTime
  isSent        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Conversation {
  id         String   @id @default(uuid())
  salonId    String
  customerId String
  language   String   @default("ENGLISH")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  salon      Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([salonId, customerId])
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  content        String
  direction      MessageDirection
  language       String?          @default("ENGLISH")
  timestamp      DateTime         @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  voiceNote      VoiceNote?
}

model Campaign {
  id            String   @id @default(uuid())
  salonId       String
  name          String
  content       String   // The WhatsApp message template
  targetSegment String   // E.g. "inactive_30_days"
  sentCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salon         Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  salonId   String
  userId    String?
  action    String   // E.g. "UPDATED_SETTINGS", "DELETED_APPOINTMENT"
  details   Json?
  createdAt DateTime @default(now())

  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model MissedCall {
  id        String   @id @default(uuid())
  salonId   String
  phone     String
  timestamp DateTime @default(now())
  source    String   @default("TELCO") // "TELCO" or "MANUAL"
  status    String   @default("PENDING") // "PENDING", "CONVERSATION_STARTED", "BOOKED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([phone])
}

model ReviewCampaign {
  id            String    @id @default(uuid())
  salonId       String
  customerId    String
  appointmentId String    @unique
  sentAt        DateTime?
  clickedAt     DateTime?
  completed     Boolean   @default(false)
  message       String?
  rating        Int?      // stores 1-5 rating
  feedback      String?   // stores text comment feedback
  resolved      Boolean   @default(false) // indicates if negative feedback was resolved by manager
  resolvedAt    DateTime?
  resolverNotes String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  salon         Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
}

model RebookingRule {
  id           String   @id @default(uuid())
  salonId      String
  serviceId    String   @unique
  intervalDays Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salon        Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([salonId])
}

model RebookingRecommendation {
  id         String    @id @default(uuid())
  salonId    String
  customerId String
  serviceId  String
  dueDate    DateTime
  status     String    @default("PENDING") // "PENDING", "APPROVED", "SENT", "BOOKED", "IGNORED"
  sentAt     DateTime?
  message    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  salon      Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([customerId])
}

model VoiceNote {
  id           String   @id @default(uuid())
  messageId    String   @unique
  transcript   String
  durationSecs Int?
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Commission {
  id          String   @id @default(uuid())
  salonId     String
  staffId     String
  serviceId   String
  ratePercent Float    // e.g. 15.0 for 15%
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([salonId])
}

model CashDrawerLog {
  id          String   @id @default(uuid())
  salonId     String
  amount      Float
  actionType  String   // E.g. "OPEN", "CLOSE", "SALE", "PAYOUT"
  notes       String?
  createdById String
  createdAt   DateTime @default(now())

  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([salonId])
}

enum LeadStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_DONE
  NEGOTIATION
  CONVERTED
  LOST
}

model Lead {
  id             String            @id @default(uuid())
  leadName       String
  salonName      String?
  phone          String
  city           String?
  interestedPlan SubscriptionPlan? @default(FREE)
  demoStatus     String?           @default("NONE")
  status         LeadStatus        @default(NEW)
  followUpDate   DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum WaitingListStatus {
  WAITING
  NOTIFIED
  BOOKED
  EXPIRED
}

model WaitingList {
  id                 String            @id @default(uuid())
  salonId            String
  customerId         String
  serviceId          String
  staffId            String?
  requestedStartTime DateTime
  priority           Int               @default(1) // 1 = Normal, 2 = VIP/High
  status             WaitingListStatus @default(WAITING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  salon              Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff              Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([salonId, status])
  @@index([salonId, requestedStartTime])
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
}

enum ReportStatus {
  PENDING
  SENT
  FAILED
}

model BusinessReport {
  id             String       @id @default(uuid())
  salonId        String
  type           ReportType
  date           DateTime     // Date/Period the report covers
  content        String       // Rendered WhatsApp text
  status         ReportStatus @default(PENDING)
  retryCount     Int          @default(0)
  error          String?
  deliveredAt    DateTime?
  metrics        Json?        // Aggregated raw metrics JSON
  recommendation String?      // AI-generated recommendation
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  salon          Salon        @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, type, date])
  @@index([salonId])
}

model AdminCredential {
  id        String   @id @default(uuid())
  adminId   String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppSession {
  id        String   @id @default(uuid())
  salonId   String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, key])
  @@index([salonId])
}



